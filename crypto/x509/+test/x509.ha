use bufio;
use bytes;
use encoding::hex;
use fmt;
use io;
use os;
use memio;
use encoding::pem;
use encoding::asn1::stdoid;
use time::date;

@test fn parse_v1() void = {
	let c = open_cert(memio::fixed(ed25519cert.cert))!;

	assert(c.version == version::V1);
	let sn: [_]u8 = [
		0x72, 0x1f, 0x7b, 0x55, 0x95, 0x61, 0x9a, 0xa2, 0xa2, 0x3d,
		0x62, 0xc6, 0x4c, 0x8f, 0xce, 0xe6, 0x5b, 0xcb, 0x94, 0x7b
	];
	assert(bytes::equal(sn[..], cert_sn(&c)));
	assert(c.sigalgo == stdoid::ED25519);

	let from = date::new(date::UTC, 0, 2022, 12, 7, 16, 31, 5)!;
	assert(date::coincident(&from, &c.validfrom));

	let to = date::new(date::UTC, 0, 2024, 11, 6, 16, 31, 5)!;
	assert(date::coincident(&to, &c.validto));

// TODO check
//	Issuer: C=DE, CN=www.example.com
//      Subject: C=DE, CN=www.example.com
//      Subject Public Key Info:
//          Public Key Algorithm: ED25519
//              ED25519 Public-Key:
//              pub:
//                  72:0d:30:f0:88:d6:38:19:21:b8:c0:bc:a5:36:fa:
//                  d7:4f:06:10:db:c0:10:fb:fa:43:0e:0a:56:eb:5d:
//                  87:80

};

@test fn verify_sig() void = {
	let c = open_cert(memio::fixed(ed25519cert.cert))!;
	cert_checksigfrom(&c, &c)!;

	let c = open_cert(memio::fixed(rsapkcs1v3cert.cert))!;
	cert_checksigfrom(&c, &c)!;
};

// §4.1 UniqueIdentifier  ::=  BIT STRING
//
// We should handle or reject properly rather than aborting.
@test fn parse_cert_uid_oversize() void = {
	let der: [_]u8 = [
		// outer seq
		0x30, 0x82, 0x13, 0xFB,
		// tbs seq
		0x30, 0x82, 0x13, 0xF7,
		// version
		0xA0, 0x03, 0x02, 0x01, 0x01,
		// serial
		0x02, 0x01, 0x01,
		// signature
		0x30, 0x05, 0x06, 0x03, 0x2B, 0x65, 0x70,
		// issuer
		0x30, 0x0C, 0x31, 0x0A, 0x30, 0x08,
		0x06, 0x03, 0x55, 0x04, 0x03, 0x13, 0x01, 0x78,
		// validity
		0x30, 0x1E,
		0x17, 0x0D, 0x32, 0x35, 0x30, 0x31, 0x30, 0x31,
		0x30, 0x30, 0x30, 0x30, 0x30, 0x30, 0x5A,
		0x17, 0x0D, 0x32, 0x37, 0x30, 0x31, 0x30, 0x31,
		0x30, 0x30, 0x30, 0x30, 0x30, 0x30, 0x5A,
		// subject
		0x30, 0x00,
		// spki ed25519
		0x30, 0x2A, 0x30, 0x05, 0x06, 0x03, 0x2B, 0x65, 0x70,
		0x03, 0x21, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		// subjectUniqueID
		0x82, 0x82, 0x13, 0x88, // 5000
	];

	let buf: [128]u8 = [0...];
	match (parse_cert(&memio::fixed(der), buf)) {
	case let c: cert =>
		cert_free(&c);
		abort("expecting the oversized subjectUniqueID to be rejected");
	case nomem =>
		abort("unexpected nomem");
	case error =>
		void;
	};
};

// §4.1 issuerUniqueID [1]  IMPLICIT UniqueIdentifier OPTIONAL,
//                     ^^^  -- If present, version MUST be v2 or v3
@test fn parse_cert_issuer_uid() void = {
	let der: [_]u8 = [
		// outer
		0x30, 0x7D,
		// tbs
		0x30, 0x6F,
		// version
		0xA0, 0x03, 0x02, 0x01, 0x01,
		// serial
		0x02, 0x01, 0x01,
		// signature
		0x30, 0x05, 0x06, 0x03, 0x2B, 0x65, 0x70,
		// issuer
		0x30, 0x0C, 0x31, 0x0A, 0x30, 0x08,
		0x06, 0x03, 0x55, 0x04, 0x03, 0x13, 0x01, 0x78,
		// validity
		0x30, 0x1E,
		0x17, 0x0D, 0x32, 0x35, 0x30, 0x31, 0x30, 0x31,
		0x30, 0x30, 0x30, 0x30, 0x30, 0x30, 0x5A,
		0x17, 0x0D, 0x32, 0x37, 0x30, 0x31, 0x30, 0x31,
		0x30, 0x30, 0x30, 0x30, 0x30, 0x30, 0x5A,
		// subject
		0x30, 0x00,
		// spki
		0x30, 0x2A, 0x30, 0x05, 0x06, 0x03, 0x2B, 0x65, 0x70,
		0x03, 0x21, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		// issuerUniqueID
		0x81, 0x02, 0x00, 0x01,
		// ^ &1 = 1
		// end tbs
		// sig alg
		0x30, 0x05, 0x06, 0x03, 0x2B, 0x65, 0x70,
		// sig
		0x03, 0x03, 0x00, 0xAA, 0xBB,
	];

	let buf: [256]u8 = [0...];
	match (parse_cert(&memio::fixed(der), buf)) {
	case let c: cert =>
		cert_free(&c);
	case nomem =>
		abort("unexpected nomem");
	case error =>
		abort("expected v2 cert with issuerUniqueID to parse");
	};
};

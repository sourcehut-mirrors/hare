@test fn rsa() void = {
	test_sign(rsakey, rsacert, stdoid::SHA256_WITH_RSAENCRYPTION);
};

@test fn rsa_pss() void = {
	let params = rsapssparams {
		hashfn = stdoid::ID_SHA256,
		maskgenfn = stdoid::ID_MGF1,
		maskgenhashfn = stdoid::ID_SHA256,
		saltsz = 32,
	};

	test_sign(rsapss_key, rsapss_cert, stdoid::RSASSA_PSS, params);
};
